# ─────────────────────────────────────────────────────────────────────────────
# AgentLog Docker 环境变量配置
# ─────────────────────────────────────────────────────────────────────────────
# 复制此文件为 .env 并修改相应配置
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# 服务端口（默认 7892）
AGENTLOG_PORT=7892

# HTTP API 监听地址
# 开发环境：127.0.0.1（仅本地访问）
# 生产环境：0.0.0.0（允许外部访问）
AGENTLOG_HOST=0.0.0.0

# 数据持久化路径（相对于 docker-compose.yml 所在目录）
# 或使用绝对路径如 /home/user/.agentlog
AGENTLOG_DATA_PATH=./data

# SQLite 数据库文件路径（容器内）
AGENTLOG_DB_PATH=/data/agentlog.db
