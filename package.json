{
  "name": "agentlog",
  "version": "1.0.1",
  "private": true,
  "description": "AI 编程行车记录仪 —— 自动捕获 AI Agent 交互日志，与 Git Commit 绑定",
  "scripts": {
    "dev": "pnpm --filter @agentlog/backend dev",
    "build": "pnpm --filter @agentlog/shared build && pnpm --filter @agentlog/backend build && pnpm --filter agentlog-vscode build",
    "build:shared": "pnpm --filter @agentlog/shared build",
    "build:backend": "pnpm --filter @agentlog/backend build",
    "build:ext": "pnpm --filter agentlog-vscode build",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r exec rm -rf dist node_modules",
    "docker:build": "docker build -t agentlog:latest -f docker/Dockerfile .",
    "docker:run": "docker run -d --name agentlog -p 7892:7892 -v agentlog-data:/data agentlog:latest",
    "docker:stop": "docker stop agentlog && docker rm agentlog",
    "docker:logs": "docker logs -f agentlog",
    "docker:compose:up": "cd docker && docker-compose up -d",
    "docker:compose:down": "cd docker && docker-compose down",
    "docker:compose:logs": "cd docker && docker-compose logs -f"
  },
  "devDependencies": {
    "node-fetch": "^3.3.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "@vscode/vsce-sign",
      "keytar"
    ]
  }
}
