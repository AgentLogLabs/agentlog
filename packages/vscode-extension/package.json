{
  "name": "agentlog-vscode",
  "displayName": "AgentLog — AI 编程飞行记录仪",
  "description": "AI 编程助手必备！自动捕获 DeepSeek/Cursor/Cline 等 AI Agent 交互日志（Prompt/Reasoning/Response），与 Git Commit 智能绑定，支持一键导出周报、PR 说明、提交上下文。兼容 DeepSeek、Qwen、Kimi 等国产大模型，让 AI 编程过程全程可追溯。",
  "version": "1.1.0",
  "private": false,
  "publisher": "agentloglabs",
  "license": "Apache-2.0",
  "icon": "assets/128.png",
  "homepage": "https://github.com/AgentLogLabs/agentlog",
  "repository": {
    "type": "git",
    "url": "https://github.com/AgentLogLabs/agentlog.git"
  },
  "readme": "README.md",
  "engines": {
    "vscode": "^1.96.0",
    "node": ">=18.0.0 <24.0.0"
  },
  "categories": [
    "Other",
    "SCM Providers"
  ],
  "keywords": [
    "AI",
    "agent",
    "log",
    "deepseek",
    "qwen",
    "kimi",
    "cline",
    "cursor",
    "git",
    "prompt"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onChatParticipant:agentlog.chat",
    "onCommand:agentlog.startBackend",
    "onCommand:agentlog.stopBackend",
    "onCommand:agentlog.showBackendStatus",
    "onCommand:agentlog.openDashboard",
    "onCommand:agentlog.exportWeeklyReport",
    "onCommand:agentlog.exportPrDescription",
    "onCommand:agentlog.generateCommitContext",
    "onCommand:agentlog.generateCommitExplain",
    "onCommand:agentlog.bindCommit",
    "onCommand:agentlog.unbindCommit",
    "onCommand:agentlog.unbindTraceFromCommit",
    "onCommand:agentlog.installGitHook",
    "onCommand:agentlog.removeGitHook",
    "onCommand:agentlog.viewSessionDetail",
    "onCommand:agentlog.deleteSession",
    "onCommand:agentlog.refreshSessionList",
    "onCommand:agentlog.refreshTraceList",
    "onCommand:agentlog.viewTraceDetail",
    "onCommand:agentlog.installHooks",
    "onCommand:agentlog.uninstallHooks",
    "onCommand:agentlog.resumeContext",
    "onCommand:agentlog.configureMcpClient",
    "onCommand:agentlog.verifyMcpConnection",
    "onCommand:agentlog.resumeTraceWith",
    "onCommand:agentlog.createHandoff",
    "onCommand:agentlog.pauseTrace",
    "onCommand:agentlog.resumeFromPause",
    "onCommand:agentlog.completeTrace",
    "onCommand:agentlog.deleteTrace"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "agentlog.openDashboard",
        "title": "AgentLog: 打开交互日志面板",
        "icon": "$(history)"
      },
      {
        "command": "agentlog.exportWeeklyReport",
        "title": "AgentLog: 导出本周 AI 开发周报",
        "icon": "$(file-text)"
      },
      {
        "command": "agentlog.exportPrDescription",
        "title": "AgentLog: 导出 PR / Code Review 说明",
        "icon": "$(git-pull-request)"
      },
      {
        "command": "agentlog.generateCommitContext",
        "title": "AgentLog: 生成 Commit 上下文文档",
        "icon": "$(book)"
      },
      {
        "command": "agentlog.generateCommitExplain",
        "title": "AgentLog: 生成 Commit AI 交互解释",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "agentlog.bindCommit",
        "title": "AgentLog: 手动绑定 Commit",
        "icon": "$(git-commit)"
      },
      {
        "command": "agentlog.unbindCommit",
        "title": "AgentLog: 解除 Commit 绑定",
        "icon": "$(git-commit)"
      },
      {
        "command": "agentlog.unbindTraceFromCommit",
        "title": "AgentLog: 从此 Commit 解绑 Trace",
        "icon": "$(close)"
      },
      {
        "command": "agentlog.installGitHook",
        "title": "AgentLog: 安装 Git post-commit 钩子（自动绑定）",
        "icon": "$(git-commit)"
      },
      {
        "command": "agentlog.removeGitHook",
        "title": "AgentLog: 移除 Git post-commit 钩子",
        "icon": "$(trash)"
      },
      {
        "command": "agentlog.viewSessionDetail",
        "title": "AgentLog: 查看会话详情",
        "icon": "$(eye)"
      },
      {
        "command": "agentlog.deleteSession",
        "title": "AgentLog: 删除会话记录",
        "icon": "$(trash)"
      },
      {
        "command": "agentlog.refreshSessionList",
        "title": "AgentLog: 刷新会话列表",
        "icon": "$(refresh)"
      },
      {
        "command": "agentlog.refreshTraceList",
        "title": "AgentLog: 刷新 Trace 列表",
        "icon": "$(refresh)"
      },
      {
        "command": "agentlog.viewTraceDetail",
        "title": "AgentLog: 查看 Trace 详情",
        "icon": "$(eye)"
      },
      {
        "command": "agentlog.startBackend",
        "title": "AgentLog: 启动本地后台服务",
        "icon": "$(server-process)"
      },
      {
        "command": "agentlog.stopBackend",
        "title": "AgentLog: 停止本地后台服务",
        "icon": "$(debug-stop)"
      },
      {
        "command": "agentlog.showBackendStatus",
        "title": "AgentLog: 查看后台服务状态",
        "icon": "$(pulse)"
      },
      {
        "command": "agentlog.installHooks",
        "title": "AgentLog: 安装 Claude Code Hook（自动上报 AI 会话）",
        "icon": "$(plug)"
      },
      {
        "command": "agentlog.uninstallHooks",
        "title": "AgentLog: 移除 Claude Code Hook",
        "icon": "$(trash)"
      },
      {
        "command": "agentlog.resumeContext",
        "title": "AgentLog: 复活上下文 (Resume Context)",
        "icon": "$(debug-restart)"
      },
      {
        "command": "agentlog.configureMcpClient",
        "title": "AgentLog: 配置 AI Agent MCP 接入",
        "icon": "$(plug)"
      },
      {
        "command": "agentlog.verifyMcpConnection",
        "title": "AgentLog: 验证 MCP 连接",
        "icon": "$(check)"
      },
      {
        "command": "agentlog.resumeTraceWith",
        "title": "AgentLog: 使用指定 Agent 恢复 Trace",
        "icon": "$(debug-restart)"
      },
      {
        "command": "agentlog.createHandoff",
        "title": "AgentLog: 创建交接请求",
        "icon": "$(person)"
      },
      {
        "command": "agentlog.pauseTrace",
        "title": "AgentLog: 暂停 Trace",
        "icon": "$(debug-pause)"
      },
      {
        "command": "agentlog.resumeFromPause",
        "title": "AgentLog: 从暂停恢复",
        "icon": "$(debug-continue)"
      },
      {
        "command": "agentlog.completeTrace",
        "title": "AgentLog: 标记完成",
        "icon": "$(pass)"
      },
      {
        "command": "agentlog.deleteTrace",
        "title": "AgentLog: 删除 Trace",
        "icon": "$(trash)"
      },
      {
        "command": "agentlog.openGitHub",
        "title": "AgentLog: 帮助与反馈",
        "icon": "$(feedback)"
      }
    ],
    "chatParticipants": [
      {
        "id": "agentlog.chat",
        "fullName": "AgentLog AI 记录仪",
        "name": "agentlog",
        "description": "通过 AgentLog 记录 AI 对话（使用当前选中的 Copilot 模型）",
        "isSticky": true
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "agentlog-sidebar",
          "title": "AgentLog",
          "icon": "assets/128-icon.png"
        }
      ]
    },
    "views": {
      "agentlog-sidebar": [
        {
          "id": "agentlog.traceList",
          "name": "Trace 列表",
          "type": "tree",
          "icon": "$(debug-pause)",
          "contextualTitle": "AgentLog — Trace 列表"
        },
        {
          "id": "agentlog.commitBindings",
          "name": "Commit 绑定",
          "type": "tree",
          "icon": "$(git-commit)",
          "contextualTitle": "AgentLog — Commit 绑定"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "agentlog.commitBindings",
        "contents": "尚无 Commit 绑定记录。\n\n安装 Git 钩子后，每次 git commit 时将自动关联最近的 AI 交互会话。\n\n[安装 Git 钩子](command:agentlog.installGitHook)"
      },
      {
        "view": "agentlog.traceList",
        "contents": "尚无 Trace 记录。\n\n开始一个任务后，Trace 会自动显示在这里。\n\n[打开 Trace 面板](command:agentlog.openTracePanel)\n[查看服务状态](command:agentlog.showBackendStatus)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "agentlog.refreshTraceList",
          "when": "view == agentlog.traceList",
          "group": "navigation"
        },
        {
          "command": "agentlog.configureMcpClient",
          "when": "view == agentlog.traceList",
          "group": "navigation"
        },
        {
          "command": "agentlog.openGitHub",
          "when": "view == agentlog.traceList",
          "group": "navigation"
        },
        {
          "command": "agentlog.openDashboard",
          "when": "view == agentlog.traceList",
          "group": "navigation"
        },
        {
          "command": "agentlog.createHandoff",
          "when": "view == agentlog.traceList",
          "group": "navigation"
        },
        {
          "command": "agentlog.generateCommitContext",
          "when": "view == agentlog.commitBindings",
          "group": "export"
        },
        {
          "command": "agentlog.generateCommitExplain",
          "when": "view == agentlog.commitBindings",
          "group": "export"
        },
        {
          "command": "agentlog.installGitHook",
          "when": "view == agentlog.commitBindings",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "agentlog.unbindTraceFromCommit",
          "when": "view == agentlog.commitBindings && viewItem == commit-trace-item",
          "group": "agentlog@1"
        },
        {
          "command": "agentlog.resumeContext",
          "when": "view == agentlog.commitBindings && viewItem == commit-session",
          "group": "agentlog@2"
        },
        {
          "command": "agentlog.generateCommitContext",
          "when": "view == agentlog.commitBindings && viewItem == commit",
          "group": "agentlog@3"
        },
        {
          "command": "agentlog.generateCommitExplain",
          "when": "view == agentlog.commitBindings && viewItem == commit",
          "group": "agentlog@4"
        },
        {
          "command": "agentlog.viewTraceDetail",
          "when": "view == agentlog.traceList && viewItem =~ /trace-(running|pending-handoff|in-progress|failed|completed|paused)/",
          "group": "inline"
        },
        {
          "command": "agentlog.bindCommit",
          "when": "view == agentlog.traceList && viewItem =~ /trace-(running|pending-handoff|in-progress|failed|completed|paused)/",
          "group": "agentlog@1"
        },
        {
          "command": "agentlog.resumeContext",
          "when": "view == agentlog.traceList && viewItem =~ /trace-(running|pending-handoff|in-progress|failed|completed|paused)/",
          "group": "agentlog@2"
        },
        {
          "command": "agentlog.resumeTraceWith",
          "when": "view == agentlog.traceList && viewItem == trace-pending-handoff",
          "group": "agentlog@3"
        },
        {
          "command": "agentlog.resumeTraceWith",
          "when": "view == agentlog.traceList && viewItem == trace-failed",
          "group": "agentlog@3"
        },
        {
          "command": "agentlog.createHandoff",
          "when": "view == agentlog.traceList && viewItem == trace-running",
          "group": "agentlog@3"
        },
        {
          "command": "agentlog.pauseTrace",
          "when": "view == agentlog.traceList && viewItem == trace-running",
          "group": "agentlog@4"
        },
        {
          "command": "agentlog.pauseTrace",
          "when": "view == agentlog.traceList && viewItem == trace-in-progress",
          "group": "agentlog@4"
        },
        {
          "command": "agentlog.resumeFromPause",
          "when": "view == agentlog.traceList && viewItem == trace-paused",
          "group": "agentlog@3"
        },
        {
          "command": "agentlog.completeTrace",
          "when": "view == agentlog.traceList && viewItem == trace-in-progress",
          "group": "agentlog@5"
        },
        {
          "command": "agentlog.deleteTrace",
          "when": "view == agentlog.traceList && viewItem =~ /trace-(running|pending-handoff|in-progress|failed|completed|paused)/",
          "group": "agentlog@6"
        }
      ],
      "commandPalette": [],
      "scm/title": [
        {
          "command": "agentlog.bindCommit",
          "group": "agentlog",
          "when": "scmProvider == git"
        }
      ]
    },
    "configuration": {
      "title": "AgentLog",
      "properties": {
        "agentlog.backendUrl": {
          "type": "string",
          "default": "http://localhost:7892",
          "description": "AgentLog 本地后台服务地址。修改后需重启插件生效。",
          "order": 1
        },
        "agentlog.mcp.configuredClients": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "markdownDescription": "已完成 MCP 配置的 AI 客户端列表（由插件自动维护，请勿手动编辑）。",
          "order": 3
        },
        "agentlog.autoBindOnCommit": {
          "type": "boolean",
          "default": true,
          "description": "在执行 git commit 时，自动将最近的未绑定 AI 会话与该 Commit 关联。",
          "order": 4
        },
        "agentlog.retentionDays": {
          "type": "number",
          "default": 90,
          "minimum": 0,
          "description": "会话记录保留天数。设为 0 表示永久保留。",
          "order": 5
        },
        "agentlog.autoStartBackend": {
          "type": "boolean",
          "default": true,
          "description": "VS Code 启动时，是否自动在后台启动 AgentLog 本地服务。",
          "order": 6
        },
        "agentlog.debug": {
          "type": "boolean",
          "default": false,
          "description": "启用调试日志输出（输出到「输出」面板的 AgentLog 频道）。",
          "order": 7
        },
        "agentlog.exportLanguage": {
          "type": "string",
          "default": "zh",
          "enum": [
            "zh",
            "en"
          ],
          "enumDescriptions": [
            "中文",
            "English"
          ],
          "description": "导出周报 / PR 描述时使用的语言。",
          "order": 8
        }
      }
    },
    "statusBar": []
  },
  "scripts": {
    "postinstall": "node scripts/check-node-version.js",
    "compile": "node build.mjs",
    "watch": "node build.mjs --watch",
    "copy-webview": "node -e \"const fs=require('fs');const p=require('path');const src='src/webview';const dst='dist/webview';if(!fs.existsSync(dst))fs.mkdirSync(dst,{recursive:true});fs.readdirSync(src).forEach(f=>fs.copyFileSync(p.join(src,f),p.join(dst,f)));\"",
    "copy-backend": "node -e \"const fs=require('fs');const p=require('path');const src='../backend/dist';const dst='dist/backend';if(!fs.existsSync(dst))fs.mkdirSync(dst,{recursive:true});function copyDir(src,dst){const entries=fs.readdirSync(src,{withFileTypes:true});entries.forEach(entry=>{const srcPath=p.join(src,entry.name);const dstPath=p.join(dst,entry.name);if(entry.isDirectory()){if(!fs.existsSync(dstPath))fs.mkdirSync(dstPath,{recursive:true});copyDir(srcPath,dstPath);}else{fs.copyFileSync(srcPath,dstPath);}});}copyDir(src,dst);\"",
    "build": "node build.mjs",
    "vscode:prepublish": "node build.mjs",
    "package": "vsce package --no-dependencies",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test:fetch": "node --import tsx --test test/fetchInterception.test.ts"
  },
  "dependencies": {
    "@agentlog/shared": "workspace:*",
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.11.30",
    "@types/vscode": "^1.85.0",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^2.24.0",
    "chai": "^6.2.2",
    "esbuild": "^0.27.4",
    "mocha": "^11.7.5",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}