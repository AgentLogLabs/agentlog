{
  "name": "@agentlog/backend",
  "version": "1.1.2",
  "private": true,
  "description": "AgentLog 本地轻量后台服务（Fastify + SQLite）",
  "main": "dist/index.js",
  "bin": {
    "agentlog-mcp": "dist/mcp.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:mcp": "tsx src/mcp.ts",
    "build": "node build.mjs",
    "start": "node dist/index.js",
    "start:mcp": "node dist/mcp.js",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "node --import tsx --test test/integration.test.ts"
  },
  "dependencies": {
    "@agentlog/shared": "workspace:*",
    "@fastify/cors": "^9.0.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^9.4.3",
    "fastify": "^4.26.2",
    "nanoid": "^3.3.7",
    "simple-git": "^3.22.0",
    "ulid": "^3.0.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.11.30",
    "esbuild": "^0.27.4",
    "pino-pretty": "^11.0.0",
    "process-nextick-args": "^2.0.1",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  }
}
