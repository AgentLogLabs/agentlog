{
  "name": "openclaw-agent-log",
  "version": "1.0.0",
  "description": "OpenClaw Agent 自动存证与 Trace 生命周期管理 Skill",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "hooks": {
      "session:start": true,
      "tool:before_call": true,
      "tool:after_call": true,
      "agent:end": true,
      "session:end": true
    }
  },
  "dependencies": {
    "nanoid": "^5.1.7"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  }
}
