{
  "name": "@agentlog/agentlog-auto",
  "version": "1.1.0",
  "description": "AgentLog Auto Logging Skill for OpenClaw - automatic compliance logging",
  "main": "src/index.ts",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "test": "node --test"
  },
  "keywords": [
    "openclaw",
    "agentlog",
    "compliance",
    "audit",
    "logging"
  ],
  "openclaw": {
    "hooks": {
      "session:start": true,
      "tool:before_call": true,
      "tool:after_call": true,
      "agent:end": true,
      "session:end": true
    }
  },
  "author": "AgentLog Team",
  "license": "Apache-2.0",
  "peerDependencies": {
    "openclaw": ">=1.0.0"
  },
  "dependencies": {
    "typescript": "^5.0.0"
  }
}
